{
  "name": "ShellCheck Lint",
  "version": "1.0.0",
  "description": "Runs ShellCheck on shell scripts when edited to catch common errors, undefined variables, and style issues.",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "lib/**/*.sh",
      "strut"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run shellcheck -x -S warning on the edited file and report any issues found. If there are no issues, say nothing."
  }
}
