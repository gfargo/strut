{
  "name": "Run BATS Test on Save",
  "version": "1.0.0",
  "description": "Runs the edited BATS test file automatically to give immediate feedback on test changes.",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "tests/*.bats"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A BATS test file was just saved. Run it with `bats <filepath>` and report the results. If all tests pass, just say so briefly. If any fail, show the failures."
  }
}
