# ==================================================
# env.template — Standard stack environment variables
# ==================================================
# Copy to .<env>.env and fill in your values.
# DO NOT commit populated env files.

# ── VPS Connection ─────────────────────────────────
VPS_HOST=your.vps.ip.address
VPS_USER=ubuntu
# VPS_SSH_KEY=/path/to/your/ssh/key
# VPS_DEPLOY_DIR=/home/ubuntu/strut

# ── Registry Auth ──────────────────────────────────
# For GHCR:
# GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
# GH_TOKEN=${GH_PAT}
#
# For Docker Hub:
# DOCKER_USER=your-docker-username
# DOCKER_PASS=your-docker-password
#
# For ECR (uses aws CLI on the VPS):
# AWS_REGION=us-east-1

# ── PostgreSQL ─────────────────────────────────────
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# ── Application ────────────────────────────────────
API_SECRET_KEY=change-me-long-random-secret
PORT=8000
