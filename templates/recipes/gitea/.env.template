# Timezone for commit timestamps and scheduled jobs.
TZ=UTC

# UID/GID that Gitea runs as inside the container. 1000/1000 is safe on
# most Linux hosts and matches the default $USER on Ubuntu.
USER_UID=1000
USER_GID=1000

# Optional: set an explicit external URL for OAuth callbacks, cloned URLs, etc.
# ROOT_URL=https://git.example.com/
