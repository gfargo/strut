DOMAIN=example.com
ACME_EMAIL=admin@example.com

POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://STACK_NAME_PLACEHOLDER:change-me@postgres:5432/STACK_NAME_PLACEHOLDER

# strut's backup engine reads these to know which role/database to dump —
# must match the compose file's hardcoded POSTGRES_USER/POSTGRES_DB.
POSTGRES_USER=STACK_NAME_PLACEHOLDER
POSTGRES_DB=STACK_NAME_PLACEHOLDER

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=change-me
