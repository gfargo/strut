# Password for the Immich Postgres database.
DB_PASSWORD=change-me

# Host path where uploaded photos and videos will live. This will grow — point
# it at a large-enough disk / mount (e.g. /mnt/data/immich).
UPLOAD_LOCATION=./immich-library

# Immich release version. Pin (e.g. release-v1.100.0) for reproducible upgrades.
IMMICH_VERSION=release

# Postgres tunables (usually fine as-is).
DB_HOSTNAME=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
