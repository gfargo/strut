# MySQL password for the Ghost database.
MYSQL_PASSWORD=change-me

# strut's backup engine reads these to know which role/database to dump —
# must match the compose file's hardcoded MYSQL_USER/MYSQL_DATABASE. Without
# MYSQL_USER, backups would fall back to root, whose password is random
# (MYSQL_RANDOM_ROOT_PASSWORD=1 below) and unknown to strut.
MYSQL_USER=ghost
MYSQL_DATABASE=ghost

# Public URL your Ghost site will be served at. Ghost uses this to build
# absolute links in RSS feeds, emails, and OAuth callbacks. Include the
# protocol; no trailing slash.
GHOST_URL=https://blog.example.com

# Ghost version tag. Pin (e.g. 5.100.0) for reproducible upgrades.
GHOST_VERSION=5-alpine
