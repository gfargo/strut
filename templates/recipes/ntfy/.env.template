# Public URL the ntfy server will be reachable at. This is what your
# subscribers use and what ntfy embeds in topic URLs. Include the protocol,
# no trailing slash.
BASE_URL=https://ntfy.example.com

# Message auth default. "read-write" is open; use "deny-all" for a private
# server (requires user accounts) or "read-only" to disable public publishing.
AUTH_DEFAULT_ACCESS=read-write
