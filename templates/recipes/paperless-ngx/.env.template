# Random 32+ character secret used to sign session cookies. Generate with:
#   openssl rand -hex 32
PAPERLESS_SECRET_KEY=change-me-with-openssl-rand-hex-32

# Postgres password.
POSTGRES_PASSWORD=change-me

# strut's backup engine reads these to know which role/database to dump —
# must match the compose file's hardcoded POSTGRES_USER/POSTGRES_DB.
POSTGRES_USER=paperless
POSTGRES_DB=paperless

# Admin account (created on first boot).
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change-me

# Default document language for OCR (ISO 639-2 3-letter code).
PAPERLESS_OCR_LANGUAGE=eng

# Timezone for scheduled jobs and metadata.
PAPERLESS_TIME_ZONE=UTC

# Host path where you'll drop documents for auto-import.
CONSUME_PATH=./consume
