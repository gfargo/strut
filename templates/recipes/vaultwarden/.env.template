# Bcrypt-hashed admin token. Generate with:
#   openssl rand -base64 48 | argon2 $(openssl rand -base64 32) -e -id -k 65540 -t 3 -p 4
# Or use the plaintext form (less secure) if you understand the risk.
ADMIN_TOKEN=change-me

# Public URL you'll access Vaultwarden at (needed for correct signup links, etc).
DOMAIN=https://vault.example.com

# SMTP settings (optional — needed for user invites / password resets).
# SMTP_HOST=smtp.example.com
# SMTP_FROM=vault@example.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=vault@example.com
# SMTP_PASSWORD=change-me
