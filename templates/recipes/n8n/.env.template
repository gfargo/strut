# Random 32-byte secret used to encrypt credentials stored in n8n's DB.
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-me-please

# Public host that will serve n8n (used for webhooks and OAuth callbacks).
N8N_HOST=n8n.example.com

# Protocol used to build public URLs (webhooks etc). Set to https when behind TLS.
N8N_PROTOCOL=https

# Timezone for scheduled workflows.
GENERIC_TIMEZONE=UTC

# Basic auth (recommended). Delete both lines to disable.
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
