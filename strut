#!/usr/bin/env bash
# ==================================================
# strut — unified entry point for VPS stack management
# ==================================================
#
# Usage:
#   strut <stack> <command> [options]
#   strut list
#   strut init [--registry <type>] [--org <name>]
#   strut upgrade
#   strut --version
#
# Commands:
#   deploy  [--env <name>] [--services <profile>] [--pull-only]
#   health  [--env <name>] [--services <profile>] [--json]
#   logs    [--env <name>] <service> [--since <duration>] [--follow]
#   migrate [--env <name>] [neo4j|postgres] [--status|--up|--down N]
#   backup  [--env <name>] [neo4j|postgres|mysql|sqlite|all|verify|list|health|schedule|retention]
#   drift   [--env <name>] [detect|report|fix|monitor|history|auto-fix]
#   db:schema [--env <name>] [apply|verify|all]
#   restore [--env <name>] <file>
#   db:pull [--env <name>] [postgres|neo4j|mysql|sqlite|all] [--download-only] [--file <name>]
#   db:push [--env <name>] [postgres|neo4j|mysql|sqlite|all] [--upload-only] [--file <name>]
#   local   start|stop|reset|sync-env|sync-db|logs|test
#   shell   [--env <name>]
#   status  [--env <name>]
#   domain  <domain> <email> [--skip-ssl]
#   list
#   scaffold <new-stack-name>
#
# Examples:
#   strut my-stack deploy --env prod
#   strut my-stack deploy --env prod --services full
#   strut my-stack health --env prod --json
#   strut my-stack logs my-service --follow
#   strut my-stack migrate neo4j --status --env prod
#   strut my-stack backup postgres
#   strut my-stack db:schema all --env prod
#   strut my-stack db:pull --env prod
#   strut list
#   strut scaffold my-new-stack

set -euo pipefail

# ── Resolve STRUT_HOME via real path (follows symlinks) ───────────────────────
_resolve_script_dir() {
  local script="${BASH_SOURCE[0]}"
  while [ -L "$script" ]; do
    local link_target
    link_target="$(readlink "$script")"
    if [[ "$link_target" != /* ]]; then
      link_target="$(dirname "$script")/$link_target"
    fi
    script="$link_target"
  done
  cd "$(dirname "$script")" && pwd
}

STRUT_HOME="$(_resolve_script_dir)"
export STRUT_HOME

LIB="$STRUT_HOME/lib"

# Source config first, then load project config
source "$LIB/config.sh"
find_project_root || true  # OK if not in a project (init, --version, etc.)

# CLI_ROOT is the user's project root — where strut.conf, stacks/, and
# .env files live. Lib modules read `$CLI_ROOT/stacks/<stack>/…`, so when
# the user runs `strut` from inside an initialized project, dispatch
# correctly targets that project's stacks.
#
# Fall back to STRUT_HOME when no project root was discovered. This
# covers:
#   * Top-level commands that don't need a project (init, upgrade,
#     --version, audit, migrate wizard).
#   * Developer/test mode invocations from inside the engine repo —
#     tests override CLI_ROOT directly, but fixtures still work when run
#     in-place.
CLI_ROOT="${PROJECT_ROOT:-$STRUT_HOME}"
export CLI_ROOT

load_strut_config

source "$LIB/utils.sh"

# Unified EXIT trap — runs every cleanup registered via `strut_register_cleanup`.
# Registered here (not in utils.sh) so sourcing the library in tests doesn't
# install a trap on the test runner. Libraries (ssh mux, deploy lock, etc.)
# append their cleanup commands to STRUT_CLEANUPS rather than calling
# `trap` directly, which would clobber previously installed handlers.
STRUT_CLEANUPS=()
strut_register_cleanup() { STRUT_CLEANUPS+=("$1"); }
_strut_run_cleanups() {
  local _cmd
  for _cmd in "${STRUT_CLEANUPS[@]+"${STRUT_CLEANUPS[@]}"}"; do
    eval "$_cmd" 2>/dev/null || true
  done
}
trap '_strut_run_cleanups' EXIT

strut_register_cleanup 'ssh_mux_cleanup'

