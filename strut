# ── list command ──────────────────────────────────────────────────────────────
cmd_list() {
  echo ""
  echo -e "${BLUE}Available stacks:${NC}"
  echo ""
  if [ -d "$CLI_ROOT/stacks" ]; then
    local found=false
    for stack_dir in "$CLI_ROOT/stacks"/*/; do
      [ -d "$stack_dir" ] || continue
      local name
      name=$(basename "$stack_dir")
      [ "$name" = "shared" ] && continue
      found=true
      if [ -f "$stack_dir/docker-compose.yml" ]; then
        echo -e "  ${GREEN}✓${NC} $name   ($stack_dir)"
      else
        echo -e "  ${YELLOW}?${NC} $name   (no docker-compose.yml)"
      fi
    done
    if ! $found; then
      echo "  (none — run 'strut scaffold <name>' to create one)"
    fi
  else
    warn "No stacks/ directory found — run 'strut init' to get started"
  fi
  echo ""
}

# ── Resolve stack + env ───────────────────────────────────────────────────────

# resolve_env_file <stack> [env_name]
# Returns the path to the env file.
# If env_name is empty, defaults to .env in CLI_ROOT.
resolve_env_file() {
  local stack="$1"
  local env_name="${2:-}"
  if [ -n "$env_name" ]; then
    echo "$CLI_ROOT/.$env_name.env"
  else
    echo "$CLI_ROOT/.env"
  fi
}

# ── Main ──────────────────────────────────────────────────────────────────────

# Special top-level commands that don't need a stack
case "${1:-}" in
  --version|-v|version)
    _version_file="$STRUT_HOME/VERSION"
    if [ -f "$_version_file" ]; then
      cat "$_version_file"
    else
      echo "unknown"
    fi
    exit 0
    ;;
  init)
    shift
    cmd_init "$@"
    exit 0
    ;;
  skills)
    shift
    cmd_skills "$@"
    exit 0
    ;;
  upgrade)
    if [ ! -d "$STRUT_HOME/.git" ]; then
      fail "Strut_Home is not a git repository: $STRUT_HOME"
    fi
    _branch="${DEFAULT_BRANCH:-main}"
    log "Upgrading strut from origin/$_branch..."
    git -C "$STRUT_HOME" pull origin "$_branch"
    _version_file="$STRUT_HOME/VERSION"
    if [ -f "$_version_file" ]; then
      ok "strut upgraded to $(cat "$_version_file")"
    else
      ok "strut upgraded (version unknown)"
    fi
    exit 0
    ;;
  list|--list|-l) cmd_list; exit 0 ;;
  scaffold)       cmd_scaffold "${2:-}"; exit 0 ;;
  doctor)
    shift
    source "$LIB/cmd_doctor.sh"
    cmd_doctor "$@"
    exit $?
    ;;

  # Monitoring commands
  monitoring)
    source "$LIB/monitor.sh"
    MONITORING_CMD="${2:-}"
    shift 2 || true

    case "$MONITORING_CMD" in
      deploy)
        monitoring_deploy "$@"
        ;;
      add-target)
        monitoring_add_target "$@"
        ;;
      remove-target)
        monitoring_remove_target "$@"
        ;;
      alert-channel)
        ALERT_SUBCMD="${1:-}"
        shift || true
        case "$ALERT_SUBCMD" in
          add)
            monitoring_alert_channel_add "$@"
            ;;
          test)
            monitoring_alert_channel_test "$@"
            ;;
          *)
            fail "Unknown alert-channel subcommand: $ALERT_SUBCMD (add|test)"
            ;;
        esac
        ;;
      status)
        monitoring_status "$@"
        ;;
      *)
        echo "Usage: strut monitoring <command> [options]"
        echo ""
        echo "Commands:"
        echo "  deploy                                Deploy monitoring stack"
        echo "  add-target <stack> [env]              Add stack to monitoring"
        echo "  remove-target <stack>                 Remove stack from monitoring"
        echo "  alert-channel add <type> [options]    Configure alert channel (email|slack|webhook)"
        echo "  alert-channel test [type]             Test alert delivery"
        echo "  status [--json]                       Show monitoring status"
        echo ""
        echo "Examples:"
        echo "  strut monitoring deploy"
        echo "  strut monitoring add-target my-stack"
        echo "  strut monitoring alert-channel add email --to alerts@example.com"
        echo "  strut monitoring alert-channel test email"
        echo "  strut monitoring status --json"
        exit 1
        ;;
    esac
    exit 0
    ;;

  audit)
    # audit <vps-host> [vps-user] [ssh-key] [ssh-port] [--sudo]
    VPS_HOST="${2:-}"
    VPS_USER="${3:-ubuntu}"
    SSH_KEY="${4:-}"
    SSH_PORT="${5:-}"
    # Check for --sudo flag in any position
    for arg in "$@"; do
      [ "$arg" = "--sudo" ] && export VPS_SUDO=true
    done
    [ -n "$VPS_HOST" ] || { usage; fail "Usage: strut audit <vps-host> [vps-user] [ssh-key] [ssh-port] [--sudo]"; }
    audit_vps "$VPS_HOST" "$VPS_USER" "$SSH_KEY" "$SSH_PORT"
    exit 0
    ;;
  audit:list)
    audit_list
    exit 0
    ;;
  audit:generate)
    # audit:generate <stack-name> --from <audit-dir>
    STACK_NAME="${2:-}"
    [ -n "$STACK_NAME" ] || { usage; fail "Usage: strut audit:generate <stack-name> --from <audit-dir>"; }
    shift 2
    AUDIT_DIR=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --from=*) AUDIT_DIR="${1#*=}"; shift ;;
        --from)   AUDIT_DIR="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    [ -n "$AUDIT_DIR" ] || { usage; fail "Usage: strut audit:generate <stack-name> --from <audit-dir>"; }
    audit_generate_stack "$STACK_NAME" "$AUDIT_DIR"
    exit 0
    ;;
  migrate)
    # migrate <vps-host> [vps-user] [ssh-port] [ssh-key] [--yes] [--start-phase N]
    shift  # Remove 'migrate' command
    migrate_wizard "$@"
    exit 0
    ;;
  migrate:status)
    migrate_status
    exit 0
    ;;
  --help|-h|help) usage; exit 0 ;;
  "")             usage; exit 1 ;;
esac

STACK="${1:-}"
COMMAND="${2:-}"

[ -n "$STACK" ]   || { usage; fail "Missing stack argument"; }
[ -n "$COMMAND" ] || { usage; fail "Missing command argument"; }

# Validate stack exists
STACK_DIR="$CLI_ROOT/stacks/$STACK"
[ -d "$STACK_DIR" ] || fail "Stack not found: '$STACK'  (run 'strut list' to see available stacks)"

shift 2  # consume stack and command; remaining args are command-specific

# ── Parse universal options ───────────────────────────────────────────────────
# Only --env, --services, and --json are parsed globally.
# All other flags and positional args are passed through to command handlers.
ENV_NAME=""
SERVICES=""
JSON_FLAG=""
CMD_ARGS=()

while [[ $# -gt 0 ]]; do
  case $1 in
    --env=*)       ENV_NAME="${1#*=}"; shift ;;
    --env)         ENV_NAME="$2"; shift 2 ;;
    --services=*)  SERVICES="${1#*=}"; shift ;;
    --services)    SERVICES="$2"; shift 2 ;;
    --json)        JSON_FLAG="--json"; shift ;;
    --dry-run)     DRY_RUN="true"; export DRY_RUN; shift ;;
    *)             CMD_ARGS+=("$1"); shift ;;
  esac
done

ENV_FILE=$(resolve_env_file "$STACK" "$ENV_NAME")

# ── Dispatch ──────────────────────────────────────────────────────────────────
# Export standard context variables so all cmd_* handlers can access them
# without positional args. Handlers receive only CMD_ARGS (command-specific).
export CMD_STACK="$STACK"
export CMD_STACK_DIR="$STACK_DIR"
export CMD_ENV_FILE="$ENV_FILE"
export CMD_ENV_NAME="$ENV_NAME"
export CMD_SERVICES="$SERVICES"
export CMD_JSON="$JSON_FLAG"

# Check for --help in CMD_ARGS or as the command itself
_has_help_flag() {
  for arg in "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}"; do
    [[ "$arg" == "--help" || "$arg" == "-h" ]] && return 0
  done
  return 1
}

if _has_help_flag; then
  case "$COMMAND" in
    deploy)   _usage_deploy ;;
    stop)     _usage_stop ;;
    health)   _usage_health ;;
    logs)     _usage_logs ;;
    backup)   _usage_backup ;;
    drift)    _usage_drift ;;
    restore)  _usage_restore ;;
    db:pull)  _usage_db_pull ;;
    db:push)  _usage_db_push ;;
    domain)   _usage_domain ;;
    keys)     _usage_keys ;;
    local|prod|staging|dev) _usage_local ;;
    scaffold) _usage_scaffold ;;
    volumes)  _usage_volumes ;;
    validate) _usage_validate ;;
    rollback) _usage_rollback ;;
    *)        usage ;;
  esac
  exit 0
fi

case "$COMMAND" in
  update)              cmd_update "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  release)             cmd_release "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  deploy)              cmd_deploy "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  stop)                cmd_stop "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  health)              cmd_health ;;
  logs)                cmd_logs "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  logs:download)       cmd_logs_download "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  logs:rotate)         cmd_logs_rotate "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  backup)              cmd_backup "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  drift)               cmd_drift "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  db:schema)           cmd_db_schema "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  migrate)             cmd_migrate_schema "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  restore)             cmd_restore "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  db:pull)             cmd_db_pull "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  db:push)             cmd_db_push "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  shell)               cmd_shell ;;
  exec)                cmd_exec "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  status)              cmd_status ;;
  prune)               cmd_prune "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  volumes)             cmd_volumes "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  local|prod|staging|dev) cmd_local_env "$COMMAND" "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  debug)               cmd_debug "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  keys)                cmd_keys "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  validate)            cmd_validate ;;
  rollback)            cmd_rollback "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  domain)              cmd_domain "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}" ;;
  *)                   usage; fail "Unknown command: '$COMMAND'" ;;
esac
