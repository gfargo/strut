#!/usr/bin/env bash
# ==================================================
# strut — unified entry point for VPS stack management
# ==================================================
#
# Usage:
#   strut <stack> <command> [options]
#   strut list
#   strut init [--registry <type>] [--org <name>]
#   strut upgrade
#   strut --version
#
# Commands:
#   deploy  [--env <name>] [--services <profile>] [--pull-only]
#   health  [--env <name>] [--services <profile>] [--json]
#   logs    [--env <name>] <service> [--since <duration>] [--follow]
#   migrate [--env <name>] [neo4j|postgres] [--status|--up|--down N]
#   backup  [--env <name>] [neo4j|postgres|mysql|sqlite|all|verify|list|health|schedule|retention]
#   drift   [--env <name>] [detect|report|fix|monitor|history|auto-fix]
#   db:schema [--env <name>] [apply|verify|all]
#   restore [--env <name>] <file>
#   db:pull [--env <name>] [postgres|neo4j|mysql|sqlite|all] [--download-only] [--file <name>]
#   db:push [--env <name>] [postgres|neo4j|mysql|sqlite|all] [--upload-only] [--file <name>]
#   local   start|stop|reset|sync-env|sync-db|logs|test
#   shell   [--env <name>]
#   status  [--env <name>]
#   domain  <domain> <email> [--skip-ssl]
#   list
#   scaffold <new-stack-name>
#
# Examples:
#   strut my-stack deploy --env prod
#   strut my-stack deploy --env prod --services full
#   strut my-stack health --env prod --json
#   strut my-stack logs my-service --follow
#   strut my-stack migrate neo4j --status --env prod
#   strut my-stack backup postgres
#   strut my-stack db:schema all --env prod
#   strut my-stack db:pull --env prod
#   strut list
#   strut scaffold my-new-stack

set -euo pipefail

# ── Resolve STRUT_HOME via real path (follows symlinks) ───────────────────────
_resolve_script_dir() {
  local script="${BASH_SOURCE[0]}"
  while [ -L "$script" ]; do
    local link_target
    link_target="$(readlink "$script")"
    if [[ "$link_target" != /* ]]; then
      link_target="$(dirname "$script")/$link_target"
    fi
    script="$link_target"
  done
  cd "$(dirname "$script")" && pwd
}

STRUT_HOME="$(_resolve_script_dir)"
export STRUT_HOME

# CLI_ROOT kept for backward compatibility within lib modules
CLI_ROOT="$STRUT_HOME"
export CLI_ROOT

LIB="$STRUT_HOME/lib"

# Source config first, then load project config
source "$LIB/config.sh"
find_project_root || true  # OK if not in a project (init, --version, etc.)
load_strut_config

source "$LIB/utils.sh"
source "$LIB/docker.sh"
source "$LIB/deploy.sh"
source "$LIB/health.sh"
source "$LIB/logs.sh"
source "$LIB/backup.sh"
source "$LIB/schema.sh"
source "$LIB/volumes.sh"
source "$LIB/keys.sh"
source "$LIB/audit.sh"
source "$LIB/migrate.sh"
source "$LIB/github-token.sh"
source "$LIB/cmd_scaffold.sh"
source "$LIB/local.sh"
source "$LIB/debug.sh"

# Command handlers
source "$LIB/cmd_deploy.sh"
source "$LIB/cmd_backup.sh"
source "$LIB/cmd_drift.sh"
source "$LIB/cmd_db.sh"
source "$LIB/cmd_logs.sh"
source "$LIB/cmd_debug.sh"
source "$LIB/cmd_local.sh"
source "$LIB/cmd_domain.sh"
source "$LIB/cmd_volumes.sh"
source "$LIB/cmd_keys.sh"
source "$LIB/cmd_remote.sh"
source "$LIB/cmd_init.sh"
source "$LIB/cmd_stop.sh"
source "$LIB/cmd_skills.sh"
source "$LIB/cmd_validate.sh"
